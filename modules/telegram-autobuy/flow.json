{
  "name": "telegram-autobuy",
  "entry_node_id": "search",
  "params": [
    {
      "key": "max_price",
      "label": "Цена до",
      "control": "number",
      "required": true,
      "default": 30,
      "minimum": 1,
      "description": "Потолок цены лота. Фильтрует сам маркет — дороже в выдачу не попадёт."
    },
    {
      "key": "count",
      "label": "Сколько купить",
      "control": "number",
      "required": true,
      "default": 1,
      "minimum": 1,
      "maximum": 50,
      "description": "Сколько лотов взять из выдачи за один прогон."
    },
    {
      "key": "dry_run",
      "label": "Холостой прогон",
      "control": "toggle",
      "required": false,
      "default": true,
      "description": "Включено — покупка не выполняется, узел только сообщает что купил бы."
    }
  ],
  "nodes": [
    {
      "id": "search",
      "type": "market.search",
      "inputs": {
        "max_price": {
          "literal": "{{vars.max_price}}"
        },
        "category": {
          "literal": "telegram"
        }
      },
      "edges": {
        "next": "found"
      }
    },
    {
      "id": "found",
      "type": "logic.condition",
      "inputs": {
        "left": {
          "ref": "search.count"
        },
        "op": {
          "literal": "gt"
        },
        "right": {
          "literal": 0
        }
      },
      "edges": {
        "true": "cut"
      }
    },
    {
      "id": "cut",
      "type": "logic.take",
      "inputs": {
        "items": {
          "ref": "search.item_ids"
        },
        "count": {
          "literal": "{{vars.count}}"
        }
      },
      "edges": {
        "next": "each"
      }
    },
    {
      "id": "each",
      "type": "logic.for_each_lot",
      "inputs": {
        "item_ids": {
          "ref": "cut.items"
        }
      },
      "edges": {
        "body": "buy"
      }
    },
    {
      "id": "buy",
      "type": "market.fast_buy",
      "inputs": {
        "item_id": {
          "ref": "each.item_id"
        },
        "dry_run": {
          "literal": "{{vars.dry_run}}"
        }
      },
      "edges": {}
    }
  ]
}
